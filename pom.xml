<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>dev.cdelmonte</groupId>
  <artifactId>decode-shape</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>decode-shape</name>
  <description>
    A benchmark lab measuring where columnar integer bit-unpacking is SIMD-friendly
    and where it resists vectorization, on the MemorySegment substrate, with the
    Vector API. Not a fast-decoder library; an instrument for the failure map.
  </description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>25</maven.compiler.release>
    <jmh.version>1.37</jmh.version>
    <junit.version>5.11.3</junit.version>
    <!-- External sanity anchor only (Parquet's REAL fixed-shift scalar unpacker),
         on its own byte[] substrate. Pinned to the version inspected in Phase 0. -->
    <parquet.version>1.16.0</parquet.version>
    <!-- The incubator module must be visible at compile time, in the JMH forks,
         and in the surefire test JVM. Defined once, referenced everywhere. -->
    <vector.module>jdk.incubator.vector</vector.module>
  </properties>

  <dependencies>
    <dependency>
      <groupId>org.openjdk.jmh</groupId>
      <artifactId>jmh-core</artifactId>
      <version>${jmh.version}</version>
    </dependency>
    <dependency>
      <groupId>org.openjdk.jmh</groupId>
      <artifactId>jmh-generator-annprocess</artifactId>
      <version>${jmh.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>

    <!-- Parquet's real generated fixed-shift scalar BytePacker, used ONLY as the
         external anchor row (parquet-scalar). It runs on byte[]/ByteBuffer, NOT
         MemorySegment — reported on a separate, labelled axis per the brief. -->
    <dependency>
      <groupId>org.apache.parquet</groupId>
      <artifactId>parquet-encoding</artifactId>
      <version>${parquet.version}</version>
    </dependency>
  </dependencies>

  <build>
    <finalName>decode-shape</finalName>
    <plugins>

      <!-- Pin the build to JDK 25 regardless of the JDK that launched Maven.
           Requires a <jdk> entry (version 25) in ~/.m2/toolchains.xml. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-toolchains-plugin</artifactId>
        <version>3.2.0</version>
        <executions>
          <execution>
            <goals><goal>toolchain</goal></goals>
          </execution>
        </executions>
        <configuration>
          <toolchains>
            <jdk>
              <version>25</version>
            </jdk>
          </toolchains>
        </configuration>
      </plugin>

      <!-- Fail fast if the environment is wrong rather than producing
           uninterpretable numbers later. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <version>3.5.0</version>
        <executions>
          <execution>
            <id>enforce-environment</id>
            <goals><goal>enforce</goal></goals>
            <configuration>
              <rules>
                <requireMavenVersion><version>[3.8.0,)</version></requireMavenVersion>
                <!-- The toolchain (not the launching JVM) provides javac 25;
                     this guards the launching JVM is at least 17 so Maven runs. -->
                <requireJavaVersion><version>[17,)</version></requireJavaVersion>
              </rules>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>${maven.compiler.release}</release>
          <compilerArgs>
            <arg>--add-modules=${vector.module}</arg>
            <arg>-Xlint:all,-processing</arg>
          </compilerArgs>
          <annotationProcessorPaths>
            <path>
              <groupId>org.openjdk.jmh</groupId>
              <artifactId>jmh-generator-annprocess</artifactId>
              <version>${jmh.version}</version>
            </path>
          </annotationProcessorPaths>
        </configuration>
      </plugin>

      <!-- Tests need the incubator module too (cross-validation exercises the
           Vector API decoder). -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <argLine>--add-modules=${vector.module}</argLine>
        </configuration>
      </plugin>

      <!-- Build target/benchmarks.jar (the standard JMH uber-jar). -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <finalName>benchmarks</finalName>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>org.openjdk.jmh.Main</mainClass>
                </transformer>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>

    </plugins>
  </build>
</project>
